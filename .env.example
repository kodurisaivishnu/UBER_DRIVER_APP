NODE_ENV=development
PORT=8081

# External MongoDB (Atlas or similar)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/uber-driver-auth?retryWrites=true&w=majority

# External Redis (Upstash)
REDIS_URL=rediss://<username>:<password>@<endpoint>.upstash.io:6379

# JWT — generate a strong random secret (64+ chars)
JWT_SECRET=<generate-a-strong-64-char-secret>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Cookie — set to true in production (requires HTTPS)
COOKIE_SECURE=false

# Logging — both | terminal | file | none
LOG_OUTPUT=both
